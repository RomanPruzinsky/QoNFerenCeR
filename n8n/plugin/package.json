{
  "name": "n8n-nodes-qonferencer",
  "version": "0.1.0",
  "description": "n8n nodes for QoNFerenCeR conference platform — meal scanning, attendance, notifications.",
  "keywords": [
    "n8n-community-node-package",
    "qonferencer",
    "conference",
    "nfc"
  ],
  "license": "MIT",
  "homepage": "https://github.com/RomanPruzinsky/QoNFerenCeR",
  "author": {
    "name": "Roman Pružinský"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RomanPruzinsky/QoNFerenCeR.git",
    "directory": "n8n/plugin"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/QoNFerenCeRApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/QoNFerenCeR/QoNFerenCeR.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.65.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
