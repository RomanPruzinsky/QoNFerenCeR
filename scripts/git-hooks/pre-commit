#!/usr/bin/env bash
# QoNFerenCeR pre-commit hook

set -e

# Get list of staged .kt/.kts files (Added, Copied, Modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(kt|kts)$' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

ANDROID_STAGED=$(echo "$STAGED_FILES" | grep '^android/' || true)
BACKEND_STAGED=$(echo "$STAGED_FILES" | grep '^backend/' || true)
SHARED_STAGED=$(echo "$STAGED_FILES" | grep '^shared/' || true)

REPO_ROOT="$(git rev-parse --show-toplevel)"

run_ktlint() {
    local targetdir="$1"

    if [ ! -f "$REPO_ROOT/$targetdir/gradlew" ]; then
        echo "⏭  $targetdir: gradlew not yet — skipping (pre-setup phase)"
        return 0
    fi

    echo "→ $targetdir: running ktlintFormat..."
    (cd "$REPO_ROOT/$targetdir" && ./gradlew ktlintFormat -q) || {
        echo "❌ $targetdir: ktlintFormat failed — fix violations manually + retry commit"
        return 1
    }
    return 0
}

EXIT_CODE=0

if [ -n "$ANDROID_STAGED" ]; then
    run_ktlint "android" || EXIT_CODE=1
fi

if [ -n "$BACKEND_STAGED" ]; then
    run_ktlint "backend" || EXIT_CODE=1
fi

if [ -n "$SHARED_STAGED" ]; then
    run_ktlint "shared" || EXIT_CODE=1
fi

if [ $EXIT_CODE -ne 0 ]; then
    exit $EXIT_CODE
fi

# Re-stage formatted files
echo "$STAGED_FILES" | xargs -r git add

echo "✓ ktlint format OK"
exit 0
